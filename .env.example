# Signal Intel v3 — Environment Variables
# Add these in Vercel Dashboard → Settings → Environment Variables

# Anthropic — console.anthropic.com
# Also handles Brand24 MCP auth via connected connector on same account
ANTHROPIC_API_KEY=your_anthropic_key_here

# Brand24 OAuth token — passed to Anthropic MCP server config when available
BRAND24_TOKEN=your_brand24_oauth_token_here

# xAI (Grok) — console.x.ai
XAI_API_KEY=your_xai_key_here
